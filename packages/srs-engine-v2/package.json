{
  "name": "@gll/srs-engine-v2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    },
    "./data/mock/mock-decks": {
      "import": "./dist/data/mock/mock-decks.js",
      "types": "./dist/data/mock/mock-decks.d.ts"
    },
    "./data/mock/mock-words": {
      "import": "./dist/data/mock/mock-words.js",
      "types": "./dist/data/mock/mock-words.d.ts"
    },
    "./data/mock/mock-word-pool": {
      "import": "./dist/data/mock/mock-word-pool.js",
      "types": "./dist/data/mock/mock-word-pool.d.ts"
    },
    "./data/mock/mock-consonants": {
      "import": "./dist/data/mock/mock-consonants.js",
      "types": "./dist/data/mock/mock-consonants.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src __tests__",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ts-fsrs": "^5"
  },
  "devDependencies": {
    "typescript": "^5.7",
    "vitest": "^3"
  }
}
