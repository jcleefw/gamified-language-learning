# Reveals answers in the quiz UI (manual/E2E runs). See src/env.ts.
VITE_CHEAT_MODE=true

# Enables test-server hooks such as the deterministic sentence-config override.
# Set automatically for E2E in playwright.config.ts; leave unset for manual runs.
VITE_TEST_HOOKS=true

# Enables the curator audio-upload page (EP42-DS02). Pair with the server's
# GLL_CURATOR_MODE. Leave unset in production — the page is DCE'd when off.
VITE_CURATOR_MODE=true
