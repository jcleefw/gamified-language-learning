{
  "name": "@gll/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "seed": "tsx src/seed/cli.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1085.0",
    "@gll/api-contract": "workspace:*",
    "@gll/db": "workspace:*",
    "@gll/logger": "workspace:*",
    "@gll/srs-engine-v2": "workspace:*",
    "@gll/srs-review": "workspace:*",
    "@gll/srs-shelving": "workspace:*",
    "@hono/node-server": "^1",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "hono": "^4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.11.1",
    "tsx": "^4",
    "typescript": "^5.7",
    "vitest": "^3"
  }
