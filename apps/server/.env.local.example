# Local MinIO bucket simulating R2 (S3-compatible) for audio storage.
# Start it with: docker compose up -d
GLL_AUDIO_ENDPOINT=http://localhost:9000
GLL_AUDIO_BUCKET=gll-audio
GLL_AUDIO_ACCESS_KEY_ID=minioadmin
GLL_AUDIO_SECRET_ACCESS_KEY=minioadmin
# Public base URL the server rewrites decks.audio_key into (browser-reachable).
GLL_AUDIO_PUBLIC_URL=http://localhost:9000/gll-audio
# Enables the curator audio-upload endpoint (POST /api/curation/decks/:id/audio).
# Dev-only: leave unset in production so no mutating audio route is reachable.
GLL_CURATOR_MODE=true
